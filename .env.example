# NAVO RADIO - Environment Variables
# Copy to .env and fill in values

# Jamendo API (music)
JAMENDO_CLIENT_ID=your_jamendo_client_id

# Groq API (LLM for DJ, News, Weather)
GROQ_API_KEY=your_groq_api_key
# OpenAI API (optional, for ChatGPT instead of Groq) — в настройках админки переключить провайдер
OPENAI_API_KEY=

# Weather API
WEATHER_API_KEY=your_weather_api_key

# TTS: edge-tts (default) or elevenlabs
TTS_PROVIDER=edge-tts
# Скорость: +20% быстрее, -50% медленнее (по умолчанию +25%)
TTS_RATE=+25%
# Громкость TTS (DJ, новости, погода): +30% или +50% — если тише музыки
TTS_VOLUME=+0%
# Тон: +50Hz выше, -50Hz ниже
TTS_PITCH=+0Hz
# ElevenLabs API (для TTS при tts_provider=elevenlabs в настройках)
ELEVENLABS_API_KEY=

# Database
DATABASE_URL=sqlite:///./navo.db

# Смещение эфира (сек): +120 = на 2 мин вперёд при запаздывании, -60 = на 1 мин назад
SYNC_OFFSET_SECONDS=0
# Задержка «Сейчас в эфире» (сек): компенсация буферов FFmpeg/Icecast/плеера. 3–5 сек при рассинхроне
NOW_PLAYING_DELAY_SECONDS=5

# Server
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
FRONTEND_PORT=5173
# URL для плейлиста эфира (чтобы слушатели из интернета получали правильные ссылки)
BASE_URL=https://navoradio.com
# URL стрима: /stream (относительный) или полный https://...
STREAM_URL=/stream

# Icecast (для единого эфира)
ICECAST_SOURCE_PASSWORD=navo-icecast-source-2024
# URL Icecast для плеера. Локально: http://localhost:8001/live. Продакшен: https://navoradio.com/live
ICECAST_STREAM_URL=http://localhost:8001/live

# Безопасность и мониторинг
# CORS (через запятую). Пусто = дефолт localhost + navoradio.com
# CORS_ORIGINS=
# API-ключ админки. Пусто = без авторизации (для dev)
# ADMIN_API_KEY=
# Макс. размер загрузки (байт). 52428800 = 50 MB
# UPLOAD_MAX_BYTES=52428800
# Усиление подкастов/интро при загрузке. 1.5 ≈ +3.5 dB (если тише музыки)
# PODCAST_INTRO_VOLUME_BOOST=1.0